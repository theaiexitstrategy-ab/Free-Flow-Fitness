# ─────────────────────────────────────────────────────────────
# Free Flow Fitness — standalone funnel env
# The booking/billing BACKEND lives in the GoElev8 portal.
# This app only needs to know how to reach the portal securely.
# Copy to .env.local and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# Portal API base (no trailing slash). e.g. https://portal.goelev8.ai
PORTAL_API_URL=

# Shared secret sent as `x-goelev8-secret` on server->portal calls.
# Server-side ONLY — never exposed to the browser.
GOELEV8_WEBHOOK_SECRET=

# Tenant slug the portal uses to route Free Flow Fitness records.
FREEFLOW_TENANT_SLUG=freeflow_fitness_stl

# Public site URL (used for Stripe success/cancel return + canonical).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Studio contact shown on the page (safe to expose).
NEXT_PUBLIC_STUDIO_PHONE=314-625-2323
